// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/kubernetes-helm
{
	"name": "opentelemetry patterns lab",
	"image": "ubuntu:noble",

	"hostRequirements": {
		"cpus": 2
	},

	"features": {
		"ghcr.io/devcontainers/features/python:1.8.0": { "version": "3.14.3" },
		"ghcr.io/devcontainers-extra/features/wget-apt-get:1.0.17": {}, // Intentionally no version specified as it's not available}
		"ghcr.io/devcontainers/features/github-cli:1.1.0": { "version": "2.87.3" }
	},

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "pip install -r .devcontainer/requirements.txt && python environment_installer.py",

	// Add recommended secrets
	"secrets": {
	 	  "DT_ENVIRONMENT_ID": {
	            "description": "eg. abc12345 from https://abc12345.live.dynatrace.com"
		},
		  "DT_ENVIRONMENT_TYPE": {
			"description": "eg. live, sprint or dev. If unsure, use live."
		},
		  "DT_API_TOKEN": {
	    	    "description": "Dynatrace API token with these permissions: `logs.ingest`"
		}
	}
}
